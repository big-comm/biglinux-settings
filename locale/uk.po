# File: usr/share/biglinux/biglinux-settings/sleep_page.py, line: 110
#: NEEDS WORK
msgid ""
"Prevents the Realtek WiFi chip from fully powering off (d3cold), avoiding connection loss after "
"resume."
msgstr "Запобігає повному вимкненню чіпа WiFi Realtek (d3cold), уникаючи втрати з'єднання після відновлення."
# 
# File: usr/share/biglinux/biglinux-settings/sleep_page.py, line: 116
#: NEEDS WORK
