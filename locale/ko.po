# 
# File: biglinux-settings/usr/share/biglinux/biglinux-settings/performance_games_page.py, line: 83
msgid "Disables S.M.A.R.T disk monitoring. Reduces disk I/O and CPU usage."
msgstr "S.M.A.R.T 디스크 모니터링을 비활성화합니다. 디스크 I/O 및 CPU 사용량을 줄입니다."
# 
