#!/bin/bash
# Wrapper to run BigLinux Settings GUI

# Detect installation directory
# FIRST check for local/development directory (relative to script location)
SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
LOCAL_DIR="$SCRIPT_DIR/../share/biglinux/biglinux-settings"

if [[ -e "$LOCAL_DIR/main.py" ]]; then
    # Development mode - use local directory
    APP_DIR="$LOCAL_DIR"
else
    # Installed mode - look in system paths
    APP_DIR="/usr/share/biglinux/biglinux-settings"
fi

cd "$APP_DIR" || exit 1
exec -a br.com.biglinux-settings python3 main.py
